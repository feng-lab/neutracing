{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "neutracing-download-counter",
  "main": "src/index.js",
  "compatibility_date": "2026-04-15",
  "workers_dev": false,
  "preview_urls": false,
  "durable_objects": {
    "bindings": [
      {
        "name": "DOWNLOAD_COUNTERS",
        "class_name": "DownloadCounter"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DownloadCounter"]
    }
  ]
}
